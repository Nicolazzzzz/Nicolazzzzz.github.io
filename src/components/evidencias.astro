---
const categories = [
  {
    slug: 'sql',
    label: 'SQL',
    desc: 'Queries, joins, views and more',
  },
  {
    slug: 'plsql',
    label: 'PL/SQL',
    desc: 'Procedures, functions and triggers',
  },
  {
    slug: 'nosql',
    label: 'NoSQL',
    desc: 'MongoDB, Redis and document databases',
  },
  {
    slug: 'proyecto-bd',
    label: 'DB Project',
    desc: 'Final database project',
  },
];
---

<section id="evidencias" class="flex flex-col section-container gap-8">
  <div class="reveal-content" style="animation-delay: 100ms;">
    <div class="flex items-center gap-3 mb-2">
      <span class="text-accent text-2xl font-bold">/</span>
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-maintext">Evidence</h2>
    </div>
    <p class="text-gray font-body">A selection of exercises showcasing my database skills</p>
  </div>

  <div class="grid grid-cols-2 gap-4 max-w-2xl reveal-content" style="animation-delay: 200ms;">
    {categories.map((cat) => (
      <a href={"/evidencias/" + cat.slug} class="group relative block p-px rounded-xl border border-accent/20 bg-background/50 hover:border-accent/60 transition-all duration-300">
        <div class="relative h-24 flex items-center justify-center text-center overflow-hidden rounded-xl px-4">
          <div class="flex flex-col items-center justify-center h-full transition-all duration-300 group-hover:scale-90 group-hover:opacity-0">
            <h3 class="text-sm sm:text-base font-bold text-maintext">{cat.label}</h3>
            <p class="text-xs text-gray mt-1">{cat.desc}</p>
          </div>
          <div class="absolute inset-0 flex items-center justify-center translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
            <span class="text-sm font-bold text-accent uppercase tracking-wider">View</span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>