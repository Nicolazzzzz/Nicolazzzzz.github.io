---
import Layout from '../../layouts/Layout.astro';

const scripts: { title: string; file: string; description: string; code: string }[] = [
  {
    title: "World Cup 2026 - insertMany",
    file: "#",
    description: "insertMany for teams, sponsors, stadiums, players and groups for the 2026 World Cup",
    code: `db.selecciones.insertMany([
    {nombre: "Colombia", colorCamiseta: "Amarrillo", capital: "Bogotá", poblacion: 60000000},
    {nombre: "Inglaterra", capital: "Londres", mundialesGanados: 1},
    {nombre: "Republica del Congo", edadPromedio: 15, continente: "África"}
]);

use("db_2026")
db.patrocinadores.insertMany([
    {nombre: "Adidas", paisOrigen: "Alemania", categoria: "Equipamiento Deportivo" },
    {nombre: "Coca-Cola", paisOrigen: "Estados Unidos", categoria: "Bebidas" },
    {nombre: "Visa", paisOrigen: "Estados Unidos", categoria: "Tecnología de Pagos" },
    {nombre: "Qatar Airways", paisOrigen: "Catar", categoria: "Aerolínea" },
    {nombre: "Hyundai-Kia", paisOrigen: "Corea del Sur", categoria: "Automotriz" },
    {nombre: "Aramco", paisOrigen: "Arabia Saudita", categoria: "Energía" },
    {nombre: "Lenovo", paisOrigen: "China", categoria: "Tecnología" }
]);

use("db_2026")
db.estadios.insertMany([
  { nombre: "Mercedes-Benz Stadium", pais: "Estados Unidos", ciudad: "Atlanta", capacidad: 71000, inauguracion: 2017 },
  { nombre: "Gillette Stadium", pais: "Estados Unidos", ciudad: "Boston", superficie: "Césped sintético", equipoLocal: "New England Patriots" },
  { nombre: "Estadio Azteca", pais: "México", ciudad: "Ciudad de México", capacidad: 87000, altitudMetros: 2200 },
  { nombre: "SoFi Stadium", pais: "Estados Unidos", ciudad: "Los Ángeles", techo: true, costoMillonesUsd: 5000 },
  { nombre: "BMO Field", pais: "Canadá", ciudad: "Toronto", equipoLocal: "Toronto FC", renovado: 2016 }
]);

use("db_2026")
db.jugadores.insertMany([
    {nombre: "Luis Díaz", club: "Bayern Munchen", paisRepresentado: "Colombia", posicion: "Extremo"},
    {nombre: "Cristiano Ronaldo", club: "Al Nassr", paisRepresentado: "Portugal", posicion: "Delantero"},
    {nombre: "Lionel Messi", club: "Inter Miami", paisRepresentado: "Argentina", posicion: "Falso 9"},
    {nombre: "Kylian Mbappé", club: "Real Madrid", paisRepresentado: "Francia", posicion: "Extremo"},
    {nombre: "Pedri González", club: "Barcelona", paisRepresentado: "España", posicion: "Mediocampista"},
]);

use("db_2026")
db.grupos.insertMany([
    {letra: "A", primerPuesto: "Corea del Sur", segundoPuesto: "México", integrantes: ["México", "Corea del Sur", "Sudáfrica", "Chequia"]},
    {letra: "B", primerPuesto: "Suiza", segundoPuesto: "Bosnia y Herzegovina", integrantes: ["Canadá", "Bosnia y Herzegovina", "Qatar", "Suiza"]},
    {letra: "C", primerPuesto: "Brasil", segundoPuesto: "Marruecos", integrantes: ["Brasil", "Marruecos", "Haití", "Escocia"]},
    {letra: "D", primerPuesto: "Turkiye", segundoPuesto: "Paraguay", integrantes: ["USA", "Paraguay", "Australia", "Turkiye"]},
    {letra: "E", primerPuesto: "Alemania", segundoPuesto: "Ecuador", integrantes: ["Alemania", "Ecuador", "Curazao", "Costa de Marfil"]},
]);
`
  },
  {
    title: "MQL Workshop: Insert & Find",
    file: "#",
    description: "insertOne, insertMany, find with filters ($gt, $lt, $and, $in) on sample_airbnb",
    code: `// ─── Ejercicio 1 — insertOne Básico ───────────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.insertOne({
  name: "Cozy Cabin Retreat",
  summary: "Una cabaña acogedora rodeada de naturaleza, perfecta para descansar.",
  property_type: "Cabin",
  price: NumberDecimal("150.00")
});

// ─── Ejercicio 2 — insertOne con Objeto Anidado ────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.insertOne({
  name: "Casa en el Cerro Santiago",
  summary: "Hermosa casa con vista panorámica en Santiago de Chile.",
  property_type: "House",
  price: NumberDecimal("200.00"),
  address: {
    market: "Santiago",
    country: "Chile"
  }
});

// ─── Ejercicio 3 — insertMany Simple ──────────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.insertMany([
  {
    name: "Studio de Arte Urbano",
    summary: "Estudio artístico en el corazón de la ciudad.",
    property_type: "Apartment",
    price: NumberDecimal("80.00")
  },
  {
    name: "Loft Minimalista",
    summary: "Espacio minimalista y moderno con luz natural.",
    property_type: "Loft",
    price: NumberDecimal("110.00")
  }
]);

// ─── Ejercicio 4 — insertMany con Arrays ──────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.insertMany([
  {
    name: "Apartamento con Todas las Comodidades",
    summary: "Apartamento céntrico con todo lo necesario para una estadía perfecta.",
    property_type: "Apartment",
    price: NumberDecimal("130.00"),
    amenities: ["Wifi", "Kitchen", "Free parking", "Air conditioning", "Washer", "Heating"]
  }
]);

// ─── Ejercicio 5 — Validación de _id duplicado ────────────────────────────
use("sample_airbnb")

const docExistente = db.listingsAndReviews.findOne({}, { _id: 1 })
print("ID existente:", docExistente._id);

// Genera error E11000 (duplicate key):
db.listingsAndReviews.insertOne({
  _id: docExistente._id,
  name: "Documento Duplicado",
  price: NumberDecimal("50.00")
});

// ─── Ejercicio 6 — find por País ──────────────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {"address.country": "Brazil"},
    {name: 1, price: 1}
);

// ─── Ejercicio 7 — find con $gt (Mayor que) ───────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {beds: {$gt: 5}},
    {name: 1, number_of_reviews: 1}
);

// ─── Ejercicio 8 — find con $lt (Menor que) ───────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {price: {$lt: NumberDecimal("75.00")}},
    {name: 1, price: 1, property_type: 1}
);

// ─── Ejercicio 9 — find con $and y Objeto Anidado ─────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find({
    $and: [
        {property_type: "Apartment"},
        {"address.market": "New York"}
    ]
});

// ─── Ejercicio 10 — find con $in ──────────────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {property_type: {$in: ["House", "Condominium"]}},
    {name: 1, price: 1, property_type: 1}
);
`
  },
  {
    title: "MQL Workshop: Find & Update",
    file: "#",
    description: "find with regex, arrays, sort/limit; updateOne, updateMany with $set, $push, $pull, $inc, upsert",
    code: `// ─── Ejercicio 11 — find con regex ────────────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {name: { $regex: "Luxury", $options: "i" }},
    {name: 1}
);

// ─── Ejercicio 12 — find en Array (amenities) ─────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {amenities: "Heating"},
    {name: 1, amenities: 1}
);

// ─── Ejercicio 13 — find y $size de Array ─────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {amenities: {$size: 20}},
    {name: 1, amenities: 1}
);

// ─── Ejercicio 14 — find con sort y limit ─────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {},
    {name: 1, price: 1, "address.country": 1}
)
.sort({price: -1})
.limit(10);

// ─── Ejercicio 15 — Proyección y Ordenamiento ─────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.find(
    {
        $or: [
            {last_review: {$exists: false}},
            {last_review: null}
        ]
    },
    {name: 1, summary: 1, description: 1, number_of_reviews: 1}
)
.sort({number_of_reviews: -1});

// ─── Ejercicio 16 — updateOne Simple ──────────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.updateOne(
    {name: "Cozy Cabin Retreat"},
    {$set: {property_type: "Entire home/apt"}}
);

// ─── Ejercicio 17 — updateOne con $set y $push ────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.updateOne(
    {name: "Casa en el Cerro Santiago"},
    {
        $set: {summary: "Casa con un Smart TV"},
        $push: {amenities: "Smart TV"}
    }
);

// ─── Ejercicio 18 — updateMany con $inc ───────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.updateMany(
    {"address.country": "Spain"},
    {$inc: {number_of_reviews: 1}}
);

// ─── Ejercicio 19 — updateMany con $pull ──────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.updateMany(
    {amenities: "Cable TV"},
    {$pull: {amenities: "Cable TV"}}
);

// ─── Ejercicio 20 — updateOne con upsert: true ────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.updateOne(
    {name: "Mansión de Prueba"},
    {
        $set: {
            name: "Mansión de Prueba",
            price: NumberDecimal("1500.00"),
            "address.country": "United States",
        }
    },
    { upsert: true }
);
`
  },
  {
    title: "MQL Workshop: Aggregation",
    file: "#",
    description: "Aggregation pipelines: $match, $group, $unwind, $bucket, $lookup, $project on sample_airbnb",
    code: `// ─── Ejercicio 21 — $match y $count ──────────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.aggregate([
  { $match: {
      amenities: { $exists: true, $type: "array" },
      $expr: { $gt: [{ $size: "$amenities" }, 10] }
    }
  },
  { $count: "total" }
]);

// ─── Ejercicio 22 — $group: Precio Promedio por País ──────────────────────
use("sample_airbnb")

db.listingsAndReviews.aggregate([
  {
    $group: {
      _id: "$address.country",
      precio_promedio: { $avg: { $toDouble: "$price" } },
      total_listings: { $sum: 1 }
    }
  },
  { $sort: { precio_promedio: -1 } }
]);

// ─── Ejercicio 23 — $group y $unwind: Top 5 Amenities ────────────────────
use("sample_airbnb")

db.listingsAndReviews.aggregate([
  { $unwind: "$amenities" },
  {
    $group: {
      _id: "$amenities",
      frecuencia: { $sum: 1 }
    }
  },
  { $sort: { frecuencia: -1 } },
  { $limit: 5 },
  {
    $project: {
      _id: 0,
      amenity: "$_id",
      frecuencia: 1
    }
  }
]);

// ─── Ejercicio 24 — $match, $group y $sort ────────────────────────────────
use("sample_airbnb")

db.listingsAndReviews.aggregate([
  {
    $group: {
      _id: "$property_type",
      cantidad: { $sum: 1 }
    }
  },
  { $sort: { cantidad: -1 } },
  {
    $project: {
      _id: 0,
      tipo_propiedad: "$_id",
      cantidad: 1
    }
  }
]);

// ─── Ejercicio 25 — $project y Conversión de Tipo ─────────────────────────
use("sample_airbnb")

db.listingsAndReviews.aggregate([
  {
    $project: {
      _id: 0,
      name: 1,
      price: 1,
      price_entero: { $toInt: { $toDouble: "$price" } }
    }
  },
  { $limit: 20 }
]);

// ─── Ejercicio 26 — Pipeline Complejo: Review Scores ─────────────────────
use("sample_airbnb")

db.listingsAndReviews.aggregate([
  { $match: { number_of_reviews: { $gte: 10 } } },
  {
    $group: {
      _id: null,
      promedio_rating: {
        $avg: "$review_scores.review_scores_rating"
      }
    }
  },
  { $project: { _id: 0, promedio_rating: 1 } }
]);

// ─── Ejercicio 27 — $bucket: Rangos de Precio ─────────────────────────────
use("sample_airbnb");

db.listingsAndReviews.aggregate([
    {
        $bucket: {
            groupBy: "$price",
            boundaries: [0, 101, 301, 1001],
            default: "1000+",
            output: {
                cantidad_listings: { $sum: 1 }
            }
        }
    }
]);

// ─── Ejercicio 28 — $lookup (Simulación de JOIN) ──────────────────────────
// Nota: colección "hosts" no existe en sample_airbnb (ejercicio teórico).
use("sample_airbnb");

db.listingsAndReviews.aggregate([
    {
        $lookup: {
            from: "hosts",
            localField: "host.host_id",
            foreignField: "host_id",
            as: "host_info"
        }
    }
]);

// ─── Ejercicio 29 — Densidad de Huéspedes por property_type ──────────────
use("sample_airbnb");

db.listingsAndReviews.aggregate([
    {
        $group: {
            _id: "$property_type",
            promedio_huespedes: { $avg: "$accommodates" }
        }
    },
    { $sort: { promedio_huespedes: -1 } }
]);

// ─── Ejercicio 30 — Análisis por Fecha: Últimas Reviews ───────────────────
use("sample_airbnb")

db.listingsAndReviews.aggregate([
  {
    $match: {
      last_review: { $exists: true, $ne: null }
    }
  },
  {
    $group: {
      _id: { año: { $year: "$last_review" } },
      cantidad_listings: { $sum: 1 }
    }
  },
  { $sort: { "_id.año": -1 } },
  {
    $project: {
      _id: 0,
      año: "$_id.año",
      cantidad_listings: 1
    }
  }
]);
`
  },
];
---

<Layout title="NoSQL | Evidence | Nicolazzz">
  <main class="min-h-screen section-container pt-32 pb-16">
    <article class="max-w-3xl mx-auto">
      <a href="/evidencias" class="text-sm font-body text-gray hover:text-maintext transition-colors mb-8 inline-block">
        ← Back to Evidence
      </a>
      <header class="mb-12">
        <p class="text-xs font-medium text-gray uppercase tracking-wider mb-3">Scripts</p>
        <h1 class="text-4xl sm:text-5xl font-heading font-bold text-maintext mb-4">NoSQL</h1>
        <p class="text-lg text-gray font-body">Queries and operations on document and key-value databases.</p>
      </header>
      <div class="space-y-4">
        {scripts.map((script, i) => (
          <div class="border border-accent/20 rounded-xl overflow-hidden bg-background/50 script-card">
            <div class="flex items-center justify-between p-4 sm:p-5 cursor-pointer select-none script-toggle" data-index={i}>
              <div class="flex-1 min-w-0">
                <h3 class="text-sm sm:text-base font-semibold text-maintext">{script.title}</h3>
                <p class="text-xs text-gray mt-0.5">{script.description}</p>
              </div>
              <div class="flex items-center gap-2 ml-3 shrink-0">
                <button class="px-3 py-1.5 text-xs font-medium rounded-full border border-accent/30 text-gray hover:text-maintext hover:border-accent/60 transition-colors view-btn">
                  View code
                </button>
                <svg class="w-4 h-4 text-gray transition-transform duration-300 chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </div>
            <div class="code-panel hidden">
              <div class="border-t border-accent/20">
                <pre class="overflow-x-auto p-4 sm:p-5 text-xs sm:text-sm leading-relaxed text-maintext font-mono bg-background/80"><code>{script.code}</code></pre>
              </div>
            </div>
          </div>
        ))}
      </div>
    </article>
  </main>
</Layout>

<script>
  document.querySelectorAll('.script-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const card = toggle.closest('.script-card');
      if (!card) return;
      const panel = card.querySelector('.code-panel');
      const chevron = card.querySelector('.chevron');
      const btn = card.querySelector('.view-btn');
      if (!panel || !chevron || !btn) return;
      const isOpen = !panel.classList.contains('hidden');
      if (isOpen) {
        panel.classList.add('hidden');
        (chevron as HTMLElement).style.transform = '';
        btn.textContent = 'View code';
      } else {
        panel.classList.remove('hidden');
        (chevron as HTMLElement).style.transform = 'rotate(180deg)';
        btn.textContent = 'Hide code';
      }
    });
  });
</script>
