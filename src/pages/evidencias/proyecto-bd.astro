---
import Layout from '../../layouts/Layout.astro';

const project = {
  title: "CocoTechSystems",
  subtitle: "Final Database Project",
  description: `CocoTechSystems is a full-stack supermarket management platform that combines a physical point-of-sale (POS) system with an e-commerce store in a single solution. It supports multi-detail sales, automatic invoice generation, end-to-end online order management (RECEIVED → PREPARING → ON_THE_WAY → DELIVERED), and administration of clients, employees, branches, and product catalog.

MySQL acts as the transactional source of truth (ACID), while MongoDB handles the read-intensive layer serving reports, dashboards, and invoice history without costly JOINs. The system implements two MongoDB design patterns: Extended Reference for invoices with historical snapshots, and Computed for pre-calculated monthly reports per branch. Security is stateless with JWT and role-based access (ADMIN, EMPLOYEE, CLIENT), including password recovery via SMTP email code.`,
  stack: [
    "Java 21", "Spring Boot 3.3.5", "MySQL 8", "MongoDB 7",
    "Spring Security + JWT", "React 19", "TypeScript", "Vite 6",
    "MUI v7", "Recharts", "Framer Motion", "Maven"
  ],
  repoURL: "https://github.com/EstebanC06/CocoTechSystems",
  images: [] as string[],
};
---

<Layout title="DB Project | Evidence | Nicolazzz">
  <main class="min-h-screen section-container pt-32 pb-16">
    <article class="max-w-3xl mx-auto">

      <a href="/evidencias" class="text-sm font-body text-gray hover:text-maintext transition-colors mb-8 inline-block">
        ← Back to Evidence
      </a>

      <header class="mb-12">
        <p class="text-xs font-medium text-gray uppercase tracking-wider mb-3">Project</p>
        <h1 class="text-4xl sm:text-5xl font-heading font-bold text-maintext mb-4">{project.title}</h1>
        <p class="text-lg text-gray font-body">{project.subtitle}</p>
      </header>

      <div class="space-y-12">

        <!-- Description -->
        <section>
          <h2 class="text-xs font-medium text-gray uppercase tracking-wider mb-4">Description</h2>
          <div class="text-subtext font-body text-sm leading-relaxed space-y-4">
            {project.description.split('\n\n').map((para) => (
              <p>{para}</p>
            ))}
          </div>
        </section>

        <!-- Stack -->
        <section>
          <h2 class="text-xs font-medium text-gray uppercase tracking-wider mb-4">Technologies</h2>
          <div class="flex flex-wrap gap-2">
            {project.stack.map((tech) => (
              <span class="px-3 py-1 text-sm font-medium rounded-full border border-accent/20 text-subtext hover:border-accent/60 hover:text-maintext transition-all duration-300 cursor-default">
                {tech}
              </span>
            ))}
          </div>
        </section>

        <!-- Repository -->
        <section>
          <h2 class="text-xs font-medium text-gray uppercase tracking-wider mb-4">Repository</h2>
          <a
            href={project.repoURL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl border border-accent/20 text-sm text-subtext hover:border-accent/60 hover:text-maintext transition-all duration-300"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12" />
            </svg>
            GitHub — EstebanC06/CocoTechSystems
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </section>

        <!-- Gallery -->
        <section>
          <h2 class="text-xs font-medium text-gray uppercase tracking-wider mb-4">Gallery</h2>
          {project.images.length > 0 ? (
            <div class="grid grid-cols-1 gap-8">
              {project.images.map((src) => (
                <div class="relative rounded-2xl overflow-hidden border border-accent/20">
                  <img src={src} alt="Project screenshot" class="w-full h-auto" loading="lazy" />
                </div>
              ))}
            </div>
          ) : (
            <div class="flex flex-col items-center justify-center py-16 text-center border border-dashed border-accent/30 rounded-2xl">
              <span class="text-4xl mb-4">🖼️</span>
              <p class="text-gray font-body text-sm">Screenshots will be added when available.</p>
            </div>
          )}
        </section>

      </div>
    </article>
  </main>
</Layout>